{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "indonesia-regions",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
